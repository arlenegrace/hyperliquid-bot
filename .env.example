HL_API_BASE_URL=https://api.hyperliquid.xyz
WATCHLIST=BTC,ETH,SOL,CRV,BNB,XRP,SUI
POLL_INTERVAL_MS=60000
EXECUTION_MODE=paper
ACTIVE_STRATEGY=manual-range-trading-v1
LIVE_TRADING_ENABLED=false
LIVE_DRY_RUN=true
HL_USE_TESTNET=false
HL_ACCOUNT_ADDRESS=0xYOUR_TRADING_WALLET_ADDRESS
HL_PRIVATE_KEY=0xYOUR_TRADING_WALLET_PRIVATE_KEY
LIVE_STATE_FILE=.live-broker-state.json
LIVE_DEFAULT_LEVERAGE=max
LIVE_MARGIN_MODE=cross
LIVE_MAX_NOTIONAL_USD=1000
LIVE_MAX_OPEN_POSITIONS=3
LIVE_SLIPPAGE_BPS=10
LIVE_ORDER_TIMEOUT_MS=10000

RANGE_LOOKBACK_CANDLES=500
PAPER_STARTING_BALANCE_USD=20
POSITION_SIZE_USD=100
MANUAL_RANGE_MAX_RISK_PCT=0.05
# Max stop distance beyond range low/high as a fraction of range width (0.25 = 25%; default 0.5 matches prior hardcoded cap)
MANUAL_RANGE_MAX_STOP_EXTENSION_PCT=0.5
STOP_BUFFER_PCT=0.001
PIVOT_STRENGTH=3
PIVOT_CLUSTER_TOLERANCE_PCT=0.012
RANGE_MIN_BOUNDARY_TOUCHES=2
RANGE_MIN_WIDTH_PCT=0.06
RANGE_MAX_WIDTH_PCT=0.18
RANGE_MAX_AGE_CANDLES=90
RANGE_INSIDE_CLOSE_RATIO=0.55
RECLAIM_LOOKBACK_CANDLES=12
LADDER_LEVELS=5
LADDER_ENTRY_BAND_PCT=0.2
LADDER_EXIT_START_PCT=0.5
LADDER_EXIT_END_PCT=1
SIGNAL_EXPIRY_CANDLES=18
MANUAL_RANGE_FILE=manual-ranges.json
MANUAL_RANGE_STATE_FILE=.manual-range-state.json
MANUAL_RANGE_INVALIDATION_EXTEND_PCT=0.5
BACKTEST_SYMBOLS=BTC,ETH,SOL,CRV,BNB
# Optional. When set, backtest strategies begin evaluating after this instant (ISO 8601 UTC). Defaults to 2026-02-21 if omitted.
# BACKTEST_TRADING_START=2025-11-01T00:00:00.000Z
BACKTEST_LOOKBACK_CANDLES=900
BACKTEST_TRADING_FEE_RATE=0.00045
BACKTEST_SLIPPAGE_RATE=0.001
