# Copy to .env and fill in. Keep secrets here only; tune the bot in config.json (see config.example.json).

# Optional: path to JSON config (default ./config.json). Copy config.example.json → config.json to start.
# HL_BOT_CONFIG=config.json

HL_ACCOUNT_ADDRESS=0xYOUR_TRADING_WALLET_ADDRESS
HL_PRIVATE_KEY=0xYOUR_TRADING_WALLET_PRIVATE_KEY
